# ===========================================
# GoToLinks Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# ===========================================
# DATABASE (Supabase PostgreSQL via Prisma)
# ===========================================
# Get from Supabase Dashboard -> Connect -> Transaction Pooler
# MUST be Transaction Pooler (port 6543), NOT Direct Connection (port 5432)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection for migrations (optional, use if needed)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ===========================================
# AUTHENTICATION
# ===========================================
# JWT Secret for token signing (generate a random 32+ char string)
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"

# Session expiry in days
SESSION_EXPIRY_DAYS=7

# ===========================================
# CLOUDINARY (File Uploads)
# ===========================================
# Get from Cloudinary Dashboard -> Settings -> API Keys
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ===========================================
# STRIPE (Payments)
# ===========================================
# Test mode key (already available in Emergent environment)
STRIPE_SECRET_KEY="sk_test_emergent"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Pro plan price (in cents for Stripe)
STRIPE_PRO_PRICE_AMOUNT=19.00
STRIPE_PRO_PRICE_ID=""

# ===========================================
# APP CONFIGURATION
# ===========================================
# Base URL for the app (used for OAuth callbacks, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================================
# EMERGENT AUTH (Google OAuth)
# ===========================================
# No configuration needed - handled by Emergent Auth service
# Auth URL: https://auth.emergentagent.com
