// Prisma Schema for GoToLinks
// Wellness Link-in-Bio SaaS Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===========================================
// USER & AUTHENTICATION
// ===========================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?   // Null for OAuth users
  firstName     String?
  lastName      String?
  handle        String    @unique
  plan          Plan      @default(FREE)
  picture       String?
  
  // OAuth fields
  googleId      String?   @unique
  authProvider  AuthProvider @default(EMAIL)
  
  // Stripe
  stripeCustomerId String? @unique
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  profile       Profile?
  sessions      Session[]
  analytics     Analytics[]
  payments      Payment[]
  
  @@index([email])
  @@index([handle])
}

model Session {
  id            String   @id @default(uuid())
  userId        String
  sessionToken  String   @unique
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([sessionToken])
  @@index([userId])
}

enum Plan {
  FREE
  PRO
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

// ===========================================
// PROFILE & BLOCKS
// ===========================================

model Profile {
  id            String   @id @default(uuid())
  userId        String   @unique
  
  // Profile Info
  name          String
  headline      String?
  bio           String?
  photoUrl      String?
  videoUrl      String?  // Pro feature: video hero
  location      String?
  theme         String   @default("zen-minimal")
  
  // Custom domain (Pro feature)
  customDomain  String?  @unique
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks        Block[]
  
  @@index([userId])
}

model Block {
  id            String    @id @default(uuid())
  profileId     String
  type          BlockType
  order         Int       @default(0)
  isVisible     Boolean   @default(true)
  
  // Block Data (JSON for flexibility)
  title         String?
  url           String?
  description   String?
  
  // Retreat-specific
  dateRange     String?
  location      String?
  price         Float?
  
  // Testimonial-specific
  authorName    String?
  authorPhoto   String?
  quote         String?
  
  // Contact-specific
  phone         String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  profile       Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  clicks        Analytics[]
  
  @@index([profileId])
  @@index([type])
}

enum BlockType {
  LINK
  RETREAT
  TESTIMONIAL
  BOOK_CALL
  WHATSAPP
  TELEGRAM
  SOCIAL
}

// ===========================================
// ANALYTICS
// ===========================================

model Analytics {
  id            String        @id @default(uuid())
  userId        String
  blockId       String?
  eventType     AnalyticsEvent
  
  // Metadata
  referrer      String?
  userAgent     String?
  country       String?
  city          String?
  
  createdAt     DateTime      @default(now())
  
  // Relations
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  block         Block?        @relation(fields: [blockId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([blockId])
  @@index([eventType])
  @@index([createdAt])
}

enum AnalyticsEvent {
  PROFILE_VIEW
  LINK_CLICK
  RETREAT_CLICK
  BOOK_CALL_CLICK
  SOCIAL_CLICK
}

// ===========================================
// PAYMENTS
// ===========================================

model Payment {
  id                String        @id @default(uuid())
  userId            String
  
  stripeSessionId   String        @unique
  stripePaymentId   String?
  
  amount            Float
  currency          String        @default("usd")
  status            PaymentStatus @default(PENDING)
  
  metadata          Json?
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([stripeSessionId])
  @@index([status])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  EXPIRED
  REFUNDED
}
